# Demo runtime config for `make demo` (see docs/deployment.md).
# Copy to `.demo.env` (gitignored) and fill in the secret values.
#
# The demo runs the API + report worker locally (Ollama needs the GPU) and
# exposes them to the Vercel frontend through a STABLE ngrok domain. Because the
# domain never changes, VITE_API_URL on Vercel is set once and never needs a
# redeploy when the tunnel restarts.

# --- ngrok ---------------------------------------------------------------------
# Reserved free static domain (ngrok dashboard -> Domains). Must match the
# VITE_API_URL configured in the Vercel project.
NGROK_DOMAIN=your-app.ngrok-free.dev
# Optional: ngrok authtoken (ngrok dashboard -> Your Authtoken). If set, `make demo`
# configures ngrok with it on every run; otherwise run `ngrok config add-authtoken <token>`
# once and leave this blank.
NGROK_AUTHTOKEN=

# --- Ports (fixed so the ngrok target and DB/Redis URLs are stable) ------------
API_PORT=3111
POSTGRES_PORT=54399
REDIS_PORT=63799

# --- Local infra (started by docker compose; usually no need to change) --------
DATABASE_URL=postgresql://app:app@127.0.0.1:54399/app_local
REDIS_URL=redis://127.0.0.1:63799

# --- LLM (local Ollama) --------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
# qwen2.5:7b only — it is the better extractor with the loose analyst schema, and a 12B
# fallback is a dead weight on a 6 GB GPU (a single call exceeds the analyst timeout).
LLM_MODEL_POOL=qwen2.5:7b
LLM_NODE_TIMEOUT_SCALE=6

# --- Secrets (DO NOT COMMIT — fill these in .demo.env) -------------------------
# Real Supabase project so the Vercel login and the API JWKS verification match.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
# Tavily web-search key used by the report worker.
TAVILY_API_KEY=tvly-xxx
