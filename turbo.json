{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["VITE_*", "NODE_ENV"],
      "outputs": ["dist/**", "out/**", ".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputLogs": "errors-only",
      "inputs": [
        "src/**",
        "test/**",
        "scripts/**",
        "vitest.config.ts",
        "vitest.config.js",
        "package.json",
        "tsconfig*.json",
        ".env.test"
      ],
      "cache": true
    },
    "format": {},
    "format:check": {},
    "check": {
      "dependsOn": ["format:check", "typecheck", "test", "build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
