{
  "name": "@repo/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas/*": "./src/schemas/*",
    "./types/*": "./src/types/*",
    "./constants/*": "./src/constants/*",
