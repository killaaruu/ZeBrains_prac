# Database (required)
DATABASE_URL="postgresql://user:password@localhost:5432/app"
# Optional read replica
DATABASE_READONLY_URL=

# Server
PORT=3111

# Supabase Auth — used for JWKS verification (and optional HMAC fallback)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=
SUPABASE_WEBHOOK_SECRET=

# Supabase Storage (publishable/secret key pair: sb_publishable_… / sb_secret_…).
# SUPABASE_STORAGE_URL falls back to SUPABASE_URL if unset.
SUPABASE_STORAGE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Redis — BullMQ task queue
REDIS_URL=redis://localhost:6379

# Agent runtime - TrendScout (LLM via 302.ai provider).
# API key for the LLM provider (302.ai or any OpenAI-compatible API).
LLM_API_KEY=
# Base URL for the OpenAI-compatible LLM API (default: 302.ai).
LLM_BASE_URL=https://api.302.ai/v1
# Comma-separated ordered list of model names to try (primary → fallback).
LLM_MODEL=gpt-4o-mini
TAVILY_API_KEY=
# Multiplier on per-node LLM timeouts. Keep 1; raise on slow connections.
LLM_NODE_TIMEOUT_SCALE=1

# Service tokens — optional JSON map for machine-to-machine auth, e.g.
# SERVICE_TOKENS='{"my-token":{"module":"example","role":"editor"}}'
SERVICE_TOKENS=

# Local dev auth bypass (set by `pnpm local:dev`; leave unset in real envs)
# LOCAL_DEV_AUTH_ENABLED=false

# Build metadata (optional)
GIT_SHA=
GIT_BRANCH=
