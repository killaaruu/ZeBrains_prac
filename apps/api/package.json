{
  "name": "@repo/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:worker": "node dist/worker",
    "dev:worker": "nest start --watch --entryFile worker",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests --reporter=dot --pool=threads --no-isolate --maxWorkers=1 --no-file-parallelism",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config ./test/vitest-e2e.config.ts",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "migrate": "pnpm --filter @repo/db-backend migrate"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@bull-board/nestjs": "^6.20.6",
    "@langchain/langgraph": "^1.4.4",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@repo/db-backend": "workspace:*",
    "@repo/shared": "workspace:*",
    "@supabase/supabase-js": "^2.105.4",
    "bullmq": "^5.70.4",
    "jwks-rsa": "^4.0.1",
    "nestjs-cls": "^6.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22",
    "@types/supertest": "^7.2.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5",
    "unplugin-swc": "^1.5.9"
  }
}
